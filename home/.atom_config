"*":
  "atom-material-ui": {}
  core:
    allowPendingPaneItems: false
    audioBeep: false
    autoHideMenuBar: true
    automaticallyUpdate: false
    disabledPackages: [
      "wrap-guide"
      "terminal-plus"
      "vim-mode"
    ]
    ignoredNames: [
      ".git"
      ".hg"
      ".svn"
      ".DS_Store"
      "._*"
      "Thumbs.db"
      "*.pyc"
      "*.swp"
      "*.swm"
      "*.swn"
    ]
    telemetryConsent: "limited"
    themes: [
      "one-light-ui"
      "one-light-syntax"
    ]
  editor:
    fontFamily: "Menlo"
    invisibles: {}
    lineHeight: 1.3
    scrollPastEnd: true
    tabLength: 4
    zoomFontWhenCtrlScrolling: false
  "exception-reporting":
    userId: "e06395c2-a317-8715-f5e4-25213dd4934f"
  "file-icons":
    tabPaneIcon: false
  "one-dark-ui":
    fontSize: 12
  "one-light-ui":
    fontSize: 12
    hideDockButtons: true
  "seti-icons": {}
  tabs:
    enableMruTabSwitching: false
  "tree-view":
    hideIgnoredNames: true
  "vim-mode": {}
  "vim-mode-plus":
    notifiedCoffeeScriptNoLongerSupportedToExtendVMP: true
  welcome:
    showOnStartup: false
".makefile.source":
  editor:
    showIndentGuide: false
